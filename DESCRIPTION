Package: TukeyC
Version: 1.4-0
Date: 2026-05-16
Title: Conventional Tukey Test
Authors@R: c(person("J. C.", "Faria",
                    role = "aut",
                    email = "joseclaudio.faria@gmail.com"),
             person("E. G.", "Jelihovschi",
